{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "api/chat.py", "use": "@vercel/python" },
    { "src": "api/analyze.py", "use": "@vercel/python", "config": { "maxDuration": 60 } },
    { "src": "api/blob-upload.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "api/chat.py" },
    { "src": "/api/analyze", "dest": "api/analyze.py" },
    { "src": "/api/blob-upload", "dest": "api/blob-upload.js" },
    { "src": "/(.*)", "dest": "public/$1" }
  ]
}
